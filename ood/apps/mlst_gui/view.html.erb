<%- if host && port -%>
<div class="d-flex flex-column gap-3 py-2">
  <div class="d-flex gap-3 justify-content-center">
    <a href="/rnode/<%= host %>/<%= port %>/" target="_blank" class="btn btn-success btn-lg px-4">
      🧬 Open MLST
    </a>
  </div>
  <p class="text-center text-muted small mb-0">
    Select a project sample (reads or an assembly), then Run to autodetect the PubMLST scheme and ST.
  </p>
</div>
<%- end -%>
